{
  "compilerOptions": {
    "target": "es5",
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "forceConsistentCasingInFileNames": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "node",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@codewinglet/*": ["./src/*"],
      "@codewinglet/utils": ["./src/utils/index.ts"],
      "@codewinglet/components": ["./src/components/index.ts"],
      "@codewinglet/assets": ["./src/assets/index.ts"],
      "@codewinglet/constants": ["./src/constants/index.ts"]
    }
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts",
    "src/app/technology/[...slug]",
    "src/modules/AboutUs/WhyWork/Statics.jsx"
  ],
  "exclude": ["node_modules"]
}
